  /* =========================================================
   Work / projects
========================================================= */
.project-card{ background: var(--surface); border:1px solid var(--border); border-radius: var(--radius-md); overflow:hidden; transition: transform .3s var(--ease), border-color .3s; }
.project-card:hover{ transform: translateY(-6px); border-color: var(--border-strong); }
.project-thumb{
  height: 170px; position:relative; padding: 14px;
  background: linear-gradient(160deg, var(--surface-2), #0d0b18);
  border-bottom:1px solid var(--border);
}
.thumb-status{ width:34px; height:5px; border-radius:4px; background: rgba(255,255,255,.12); margin: 0 auto 14px; }
.thumb-ui{ display:flex; flex-direction:column; gap:8px; align-items:center; }

.thumb-card{ width:80%; height:30px; border-radius:8px; background: rgba(139,92,246,.18); border:1px solid rgba(139,92,246,.3); }
.thumb-card.short{ width:55%; background: rgba(34,211,238,.14); border-color: rgba(34,211,238,.3); }
.thumb-fab{ width:34px; height:34px; border-radius:50%; background: var(--gradient); margin-top:6px; box-shadow:0 8px 18px -6px rgba(139,92,246,.6); }

.thumb-ring{ width:64px; height:64px; border-radius:50%; border:6px solid rgba(255,255,255,.08); border-top-color: var(--cyan); border-right-color: var(--blue); margin: 4px auto; animation: spin 4s linear infinite; }
.thumb-bars{ display:flex; gap:6px; align-items:flex-end; height:30px; }
.thumb-bars span{ width:14px; border-radius:3px 3px 0 0; background: linear-gradient(180deg, var(--violet-2), var(--violet)); }
.thumb-bars span:nth-child(1){ height:60%; } .thumb-bars span:nth-child(2){ height:100%; } .thumb-bars span:nth-child(3){ height:75%; }

.thumb-grid{ display:grid; grid-template-columns: 1fr 1fr; gap:8px; width:75%; }
.thumb-grid span{ height:32px; border-radius:6px; background: rgba(96,165,250,.18); border:1px solid rgba(96,165,250,.3); }

.thumb-bubble{ height:18px; border-radius: 10px; background: rgba(139,92,246,.22); border:1px solid rgba(139,92,246,.32); margin:3px 0; }
.thumb-bubble.left{ width:60%; align-self:flex-start; }
.thumb-bubble.right{ width:50%; align-self:flex-end; background: rgba(34,211,238,.16); border-color: rgba(34,211,238,.3); margin-left:auto; }
.thumb-bubble.short{ width:38%; }

.project-body{ padding: 22px 24px 26px; }
.project-body h3{ font-size:1.05rem; margin-bottom:8px; }
.project-body p{ font-size:.88rem; margin-bottom:16px; }
.tag-row{ display:flex; gap:8px; flex-wrap:wrap; }
.tag{
  font-family: var(--font-mono); font-size:.7rem; color: var(--violet-2);
  border:1px solid rgba(139,92,246,.3); background: rgba(139,92,246,.08);
  padding: 4px 10px; border-radius:999px;
}